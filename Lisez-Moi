# --- Lancer le script archsplatts.sh --- #

# --- Copier la config --- #
mkdir -p ~/Images/Wallpapers
mkdir -p ~/Info

cd config
cp -r config/* ~/.config
cp -r Info/* ~/Info
cp -r Wallpapers/* ~/Images/Wallpapers
cp -r zshrc ~/.zshrc

# --- Paquets AUR --- #
yay -S --needed brave-origin-beta-bin papirus-folders 
papirus-folders-catppuccin-git tuxguitar

#--- NTSync (Kernel > 6.14) ---#
echo "ntsync" | sudo tee /etc/modules-load.d/ntsync.conf

